{
  "name": "work-journal",
  "version": "1.15.0",
  "description": "Work Journal Desktop App",
  "author": "Work Journal",
  "main": "main.js",
  "scripts": {
    "test": "node --test tests/inventory-logic.test.mjs",
    "start": "electron .",
    "bump": "node scripts/bump-version.js",
    "prepack": "node scripts/bump-version.js",
    "pack": "electron-builder --dir",
    "predist": "node scripts/bump-version.js",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.workjournal.app",
    "productName": "Work Journal",
    "beforeBuild": "scripts/bump-version.js",
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist"
    ],
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "dictionaries",
        "to": "dictionaries",
        "filter": [
          "*.bdic"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
