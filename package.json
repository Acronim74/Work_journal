{
  "name": "work-journal",
  "version": "1.0.0",
  "description": "Work Journal Desktop App",
  "author": "Work Journal",
  "main": "main.js",
  "scripts": {
    "test": "node --test tests/inventory-logic.test.mjs",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.workjournal.app",
    "productName": "Work Journal",
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist"
    ],
    "directories": { "output": "dist" },
    "extraResources": [
      {
        "from": "dictionaries",
        "to": "dictionaries",
        "filter": ["*.bdic"]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
